.user-index-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.banner-swiper {
  width: 100%;
  height: 40vh;
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
  margin-bottom: 0;
}

.banner-item {
  width: 100%;
  height: 100%;
  background: #e6f3e6;
}

.profile-card {
  background: #fff;
  border-radius: 20rpx;
  margin: -60rpx 30rpx 30rpx 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.08);
  padding: 30rpx 24rpx 24rpx 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 2;
  transition: transform 0.2s, box-shadow 0.2s;
}

.profile-card.active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.18);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 24rpx;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.username {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.service-btns {
  display: flex;
  flex-direction: row;
  margin: 0 30rpx;
  margin-top: 20rpx;
  gap: 24rpx;
}

.service-btn {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36rpx 0 32rpx 0;
  transition: all 0.15s ease;
  position: relative;
}

.service-btn:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.2);
  background: #f0fff0;
}

.service-btn:active .service-icon {
  transform: scale(1.1);
}

.service-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 12rpx;
  transition: transform 0.15s ease;
}

.service-title {
  font-size: 30rpx;
  color: #222;
  font-weight: bold;
  margin-bottom: 6rpx;
  transition: color 0.15s ease;
}

.service-btn:active .service-title {
  color: #07c160;
}

/* 紧急呼救按钮样式 */
.emergency-btn {
  margin: 40rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36rpx 0 32rpx 0;
  transition: all 0.15s ease;
  position: relative;
}

.emergency-btn:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(255,77,79,0.2);
  background: #fff1f0;
}

.emergency-btn:active .emergency-icon {
  transform: scale(1.1);
}

.emergency-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 12rpx;
  transition: transform 0.15s ease;
}

.emergency-title {
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-bottom: 6rpx;
  transition: color 0.15s ease;
}

.emergency-btn:active .emergency-title {
  color: #ff7875;
}

.emergency-tip {
  font-size: 24rpx;
  color: #999;
} 