<!--pages/signup_2/signup_2.wxml-->
<view class="page-container">
  <view class="form-container">

  <!-- 头像 -->
    <view class="form-item">
      <text class="label">头像</text>
      <button wx:if="{{!userInfo.avatarurl}}"
      open-type="chooseAvatar" bindchooseavatar="onAvatarInput"
      class="avatar-button"
      ><span class="avatar-button-text">获取头像</span></button>
      <view wx:else class="avatar-container" bindtap="onAvatarTap">
        <image src="{{userInfo.avatarurl}}" class="avatar"></image>
        <view class="avatar-overlay">
          <text class="avatar-text">点击更换</text>
        </view>
      </view>
    </view>
    

    <!-- 身份选择 -->
    <view class="form-item" wx:if="{{showTypeSelector}}">
      <text class="label">身份选择</text>
      <!-- 新用户可以选择身份 -->
      <picker wx:if="{{!isUpdating}}" mode="selector" range="{{options}}" bindchange="onTypeChange">
        <view class="picker_input">
          {{selectedTypeName || '请选择身份'}}
        </view>
      </picker>
      <!-- 更新信息时只显示身份，不可修改 -->
      <view wx:else class="picker_input disabled">
        {{selectedTypeName}}
      </view>
    </view>

    
    <!-- 手机号 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" value="{{userInfo.phone}}" placeholder="请输入手机号" maxlength="11" bindinput="onPhoneInput"/>
    </view>

    

    <!-- 昵称 -->
    <view class="form-item">
      <text class="label">昵称</text>
      <input type="nickname" class="input" value="{{userInfo.nickname}}" placeholder="请输入昵称" maxlength="11" bindinput="onNicknameInput"/>

    </view>

    <!-- 年龄 -->
    <view class="form-item">
      <text class="label">年龄</text>
      <input class="input" type="number" value="{{userInfo.age}}" placeholder="请输入年龄" bindinput="onAgeInput"/>
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="label">性别</text>
      <view class="radio-group">
        <view class="radio-item {{userInfo.gender === 'male' ? 'selected' : ''}}" bindtap="selectGender" data-gender="male">
          <text>男</text>
        </view>
        <view class="radio-item {{userInfo.gender === 'female' ? 'selected' : ''}}" bindtap="selectGender" data-gender="female">
          <text>女</text>
        </view>
      </view>
    </view>

    <!-- 获取模糊地址 -->
    <view class="form-item">
      <text class="label">地址选择</text>
      <picker mode="region" bindchange="onAddressChange">
        <view class="picker_input" >
          {{userInfo.region[0] || '请选择地址'}}
          {{userInfo.region[1]}}
          {{userInfo.region[2]}}
        </view>
      </picker>
    </view>

    <!-- 详细家庭住址 -->
    <view class="form-item">
      <text class="label">家庭住址</text>
      <textarea class="textarea" value="{{userInfo.address}}" placeholder="请输入详细住址" maxlength="200" bindinput="onAddressInput"/>
    </view>

    <!-- 提交按钮 -->
    <button wx:if="{{formChanged}}" class="submit-btn" bindtap="handleSubmit">确认提交</button>

    <!-- 注销用户按钮 -->
    <button wx:if="{{isUpdating}}" class="deregister-btn" bindtap="onDeregister">注销用户</button>
  </view>
</view> 