.page-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 30rpx;
  box-sizing: border-box;
}

.form-container {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 30rpx;
}


.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.avatar{
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
}

.avatar-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-container:hover .avatar-overlay {
  opacity: 1;
}

.avatar-text {
  color: #fff;
  font-size: 28rpx;
}

.avatar-button {
  
  display: grid;
  width: 100px; /* 按钮宽度 */
  height: 40px; /* 按钮高度 */
  background-color: #1aad19; /* 按钮背景颜色 */
  color: #fff; /* 按钮文字颜色 */
  border: none; /* 去除边框 */
  border-radius: 20px; /* 圆角 */
}

.avatar-button-text{
  text-align: center; /* 文字居中 */
  justify-content: center;
}

.input ,.picker_input{
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.picker_input {
  color: #ccc; /* 设置默认提示文字颜色 */
}

/* 禁用状态的选择器样式 */
.picker_input.disabled {
  background-color: #f0f0f0;
  color: #333;
  border: 1px solid #e0e0e0;
  display: flex;
  align-items: center;
  cursor: not-allowed;
}

.textarea {
  width: 100%;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.radio-group {
  display: flex;
  gap: 40rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.radio-item.selected {
  background: #07c160;
}

.radio-item.selected text {
  color: #fff;
}

.radio-item text {
  font-size: 28rpx;
  color: #333;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #1aad19;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 输入框placeholder样式 */
.input::placeholder,
.textarea::placeholder {
  color: #999;
}

/* 输入框聚焦时的样式 */
.input:focus,
.textarea:focus {
  background: #f0f0f0;
} 