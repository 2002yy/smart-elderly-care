/* 全局样式重置 */
page {
  padding: 0;
  margin: 0;
}

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0;
  margin: 0;
}

.page-header {
  margin-top: 0; /* 移除顶部间距 */
  margin-bottom: 30rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx; /* 添加少量内边距避免紧贴顶部 */
}

.title {
  font-size: 40rpx; /* 增大标题字号 */
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: flex;
  justify-content: center;
}

.subtitle {
  font-size: 28rpx; /* 增大副标题字号 */
  color: #999;
  display: flex;
  justify-content: center;
}

/* 管理员列表样式 */
.admin-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.admin-item {
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.admin-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.admin-name {
  font-size: 36rpx; /* 增大管理员名字号 */
  color: #333;
  font-weight: bold;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: space-between;
}

.contact-text {
  font-size: 32rpx; /* 增大联系信息字号 */
  color: #666;
  flex: 1;
}

.copy-btn {
  font-size: 26rpx;
  color: #1aad19;
  background-color: #f0f9eb;
  border: 1px solid #e1f3d8;
  border-radius: 30rpx;
  padding: 8rpx 20rpx;
  text-align: center;
  transition: all 0.3s;
}

.copy-btn:active {
  background-color: #e1f3d8;
  transform: scale(0.95);
}

/* 投诉说明样式 */
.complaint-tips {
  margin-top: 40rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 32rpx; /* 增大须知标题字号 */
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-content text {
  font-size: 30rpx; /* 增大须知内容字号 */
  color: #666;
  line-height: 1.5;
}