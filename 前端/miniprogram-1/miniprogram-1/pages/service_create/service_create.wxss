.create-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.form-picker {
  width: 100%;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #999;
}

.picker-arrow {
  width: 32rpx;
  height: 32rpx;
}

/* 禁用状态的picker */
picker[disabled] .picker-content {
  opacity: 0.6;
}

/* 禁用状态的文本 */
picker[disabled] .picker-content text {
  color: #666;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.textarea-counter {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.submit-btn.active {
  transform: scale(0.98);
  opacity: 0.9;
}

.submit-btn.disabled {
  background: #cccccc;
  color: #999999;
  opacity: 0.8;
}

/* 去除按钮默认边框 */
.submit-btn::after {
  border: none;
} 