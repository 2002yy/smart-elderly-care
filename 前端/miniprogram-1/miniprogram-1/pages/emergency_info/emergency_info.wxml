<!--pages/emergency_info/emergency_info.wxml-->
<view class="container">
  <view class="page-header">
    <view class="title">急救卡</view>
    <view class="subtitle">以下信息将在紧急情况下提供给急救人员</view>
  </view>

  <!-- 加载中提示 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 个人基本信息 -->
  <view class="card-section" wx:if="{{!loading}}">
    <view class="section-title">个人基本信息</view>
    
    <view class="info-group">
      <view class="info-item">
        <view class="info-label">姓名</view>
        <view class="info-value">{{userInfo.nickname || '未设置'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">性别</view>
        <view class="info-value">{{userInfo.gender === 'male' ? '男' : userInfo.gender === 'female' ? '女' : '未设置'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">年龄</view>
        <view class="info-value">{{userInfo.age || '未设置'}}岁</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">手机号</view>
        <view class="info-value">{{userInfo.phone || '未设置'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">住址</view>
        <view class="info-value">{{userInfo.region ? (userInfo.region + ' ' + userInfo.address) : '未设置'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">监护人电话</view>
        <view class="info-value">{{emergencyContact.phone || '未设置'}}</view>
      </view>
    </view>
  </view>

  <!-- 医疗信息 -->
  <view class="card-section" wx:if="{{!loading}}">
    <view class="section-title">医疗信息</view>
    
    <view class="info-group">
      <view class="info-item">
        <view class="info-label">血型</view>
        <view class="info-value">{{emergencyInfo.bloodType || '未设置'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">过敏史</view>
        <view class="info-value">{{emergencyInfo.allergies || '无'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">基础疾病</view>
        <view class="info-value">{{emergencyInfo.basicDiseases || '无'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">手术/植入物史</view>
        <view class="info-value">{{emergencyInfo.surgeryHistory || '无'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">用药情况</view>
        <view class="info-value">{{emergencyInfo.medication || '无'}}</view>
      </view>
      
      <view class="info-item">
        <view class="info-label">急救备注</view>
        <view class="info-value">{{emergencyInfo.emergencyNotes || '无'}}</view>
      </view>
    </view>
  </view>

  <!-- 操作区域 -->
  <view class="action-area" wx:if="{{!loading}}">
    <!-- 编辑按钮 -->
    <navigator url="/pages/emergency/emergency" class="edit-btn">
      编辑急救信息
    </navigator>
    
    <!-- 紧急求助按钮 -->
    <button class="emergency-btn {{sendingHelp ? 'disabled' : ''}}" bindtap="sendEmergencyHelp" disabled="{{sendingHelp}}">
      <text class="emergency-icon">⚠️</text>
      <text>发送紧急求助</text>
    </button>
  </view>
</view>