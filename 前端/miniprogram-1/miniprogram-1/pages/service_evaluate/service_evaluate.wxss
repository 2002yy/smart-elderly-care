.evaluate-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 服务信息卡片 */
.service-info-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.service-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.service-status {
  font-size: 28rpx;
  color: #1aad19;
  background-color: rgba(26, 173, 25, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.service-details {
  padding: 10rpx 0;
}

.detail-item {
  display: flex;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #333;
}

.detail-label {
  width: 160rpx;
  color: #666;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

/* 星级评分 */
.rating-group {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.rating-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
}

.stars {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.star {
  width: 80rpx;
  height: 80rpx;
  margin: 0 10rpx;
  opacity: 0.3;
  transition: all 0.2s;
}

.star.active {
  opacity: 1;
}

.star image {
  width: 100%;
  height: 100%;
}

.rating-text {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

/* 评价内容 */
.content-group {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.content-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.content-input {
  width: 100%;
  height: 240rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 10rpx;
}

.content-counter {
  text-align: right;
  font-size: 24rpx;
  color: #999;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 90rpx;
  background-color: #1aad19;
  color: #fff;
  border-radius: 45rpx;
  font-size: 32rpx;
  line-height: 90rpx;
  text-align: center;
  margin-top: 30rpx;
  box-shadow: 0 6rpx 16rpx rgba(26, 173, 25, 0.3);
  transition: all 0.2s;
}

.submit-btn.disabled {
  background-color: #bbb;
  box-shadow: none;
} 