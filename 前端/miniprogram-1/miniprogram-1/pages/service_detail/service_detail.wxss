.detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.detail-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.detail-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.detail-value.remark {
  font-size: 30rpx;
  color: #666;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 服务状态样式 */
.status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-weight: normal;
}

.status-1 {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-2 {
  background-color: #fff7e6;
  color: #fa8c16;
}

.status-3 {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-4 {
  background-color: #fff2e8;
  color: #fa541c;
}

.status-5 {
  background-color: #f5f5f5;
  color: #666666;
}

/* 底部按钮区域 */
.button-area {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.modify-btn {
  background: #1890ff;
  color: #fff;
}

.pay-btn {
  background: #52c41a;
  color: #fff;
}

.evaluate-btn {
  background: #fa8c16;
  color: #fff;
}

.upload-btn {
  background: #722ed1;
  color: #fff;
}

.action-btn[disabled] {
  background: #cccccc !important;
  color: #ffffff !important;
  opacity: 0.6;
}

/* 去除按钮默认边框 */
.action-btn::after {
  border: none;
} 